<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Title row -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/primary"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="8dp" />

    <!-- Counter columns (up to 5 dynamic slots) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Slot 0 -->
        <LinearLayout
            android:id="@+id/counter_slot_0"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_label_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_val_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:paddingTop="2dp"
                android:paddingBottom="4dp" />

            <Button
                android:id="@+id/btn_inc_0"
                style="@style/Widget.Habitikami.WidgetButton"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:text="@string/btn_plus" />
        </LinearLayout>

        <!-- Slot 1 -->
        <LinearLayout
            android:id="@+id/counter_slot_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_label_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_val_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:paddingTop="2dp"
                android:paddingBottom="4dp" />

            <Button
                android:id="@+id/btn_inc_1"
                style="@style/Widget.Habitikami.WidgetButton"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:text="@string/btn_plus" />
        </LinearLayout>

        <!-- Slot 2 -->
        <LinearLayout
            android:id="@+id/counter_slot_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_label_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_val_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:paddingTop="2dp"
                android:paddingBottom="4dp" />

            <Button
                android:id="@+id/btn_inc_2"
                style="@style/Widget.Habitikami.WidgetButton"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:text="@string/btn_plus" />
        </LinearLayout>

        <!-- Slot 3 -->
        <LinearLayout
            android:id="@+id/counter_slot_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_label_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_val_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:paddingTop="2dp"
                android:paddingBottom="4dp" />

            <Button
                android:id="@+id/btn_inc_3"
                style="@style/Widget.Habitikami.WidgetButton"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:text="@string/btn_plus" />
        </LinearLayout>

        <!-- Slot 4 -->
        <LinearLayout
            android:id="@+id/counter_slot_4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_label_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_val_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:paddingTop="2dp"
                android:paddingBottom="4dp" />

            <Button
                android:id="@+id/btn_inc_4"
                style="@style/Widget.Habitikami.WidgetButton"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:text="@string/btn_plus" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
