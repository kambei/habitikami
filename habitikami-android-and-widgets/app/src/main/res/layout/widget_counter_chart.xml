<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="8dp">

    <ImageView
        android:id="@+id/iv_counter_chart"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:contentDescription="Counter chart" />

    <TextView
        android:id="@+id/tv_counter_status"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:textColor="#99FFFFFF"
        android:textSize="12sp" />

    <!-- Filter label: shows current filter (e.g. "All" or "Smoking") -->
    <TextView
        android:id="@+id/tv_chart_filter"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:layout_gravity="top|start"
        android:background="@drawable/widget_button"
        android:gravity="center"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:text="All"
        android:textColor="#CCFFFFFF"
        android:textSize="10sp" />

    <ImageButton
        android:id="@+id/btn_refresh_counter_chart"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="top|end"
        android:background="@drawable/widget_button"
        android:src="@android:drawable/ic_popup_sync"
        android:scaleType="centerInside"
        android:contentDescription="@string/btn_refresh"
        android:padding="4dp" />

</FrameLayout>
