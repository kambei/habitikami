<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- Chart rendered as bitmap -->
    <ImageView
        android:id="@+id/iv_chart"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:contentDescription="@string/widget_stats_description" />

    <!-- Status text (loading / error) -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:textColor="@color/m3_on_surface_variant"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium" />

    <!-- Refresh button (top-right) -->
    <ImageButton
        android:id="@+id/btn_refresh"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="top|end"
        android:background="@drawable/widget_icon_button"
        android:src="@android:drawable/ic_popup_sync"
        android:scaleType="centerInside"
        android:contentDescription="@string/btn_refresh"
        android:padding="6dp" />

</FrameLayout>
