<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_streak_fire_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_fire"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="32sp" />

        <TextView
            android:id="@+id/tv_streak_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/m3_on_surface"
            android:textSize="42sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tv_streak_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="days streak"
            android:textColor="@color/m3_on_surface_variant"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tv_streak_habit_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/m3_on_primary_container"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingTop="6dp" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_refresh_streak"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="top|end"
        android:background="@drawable/widget_icon_button"
        android:src="@android:drawable/ic_popup_sync"
        android:scaleType="centerInside"
        android:contentDescription="@string/btn_refresh"
        android:padding="6dp" />

</FrameLayout>
