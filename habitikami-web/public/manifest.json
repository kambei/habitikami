{
  "name": "Habitikami",
  "short_name": "Habitikami",
  "description": "Build better habits, track your progress, and level up your daily routine.",
  "start_url": "/",
  "id": "/",
  "display": "standalone",
  "background_color": "#0a0a0f",
  "theme_color": "#7c3aed",
  "orientation": "any",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "protocol_handlers": [
    {
      "protocol": "web+habitikami",
      "url": "/?url=%s"
    }
  ],
  "icons": [
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon-1024x500.png",
      "sizes": "1024x500",
      "type": "image/png",
      "form_factor": "wide"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/mobile.png",
      "sizes": "768x1713",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Mobile View"
    },
    {
      "src": "/screenshots/desktop.png",
      "sizes": "768x1713",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Desktop View"
    }
  ],
  "widgets": [
    {
      "name": "Habitikami Summary",
      "short_name": "Habits",
      "description": "Daily habit progress at a glance.",
      "tag": "habit-summary",
      "template": "/widgets/habit-summary.json",
      "ms_ac_template": "/widgets/habit-summary.json",
      "data": "/widgets/data/habit-summary-data.json",
      "type": "application/json",
      "icons": [
        {
          "src": "/icons/icon-512.png",
          "sizes": "512x512",
          "type": "image/png"
        }
      ],
      "screenshots": [
        {
          "src": "/screenshots/desktop.png",
          "sizes": "768x1713",
          "type": "image/png",
          "label": "Habit Summary Widget Preview"
        }
      ],
      "update": 900
    }
  ]
}
