{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "🏯",
                  "size": "ExtraLarge"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "verticalContentAlignment": "Center",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Habitikami",
                  "size": "Medium",
                  "weight": "Bolder",
                  "color": "Accent",
                  "wrap": true
                },
                {
                  "type": "TextBlock",
                  "text": "${date}",
                  "size": "Small",
                  "isSubtle": true,
                  "spacing": "None"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Large",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Completed",
                  "size": "Small",
                  "isSubtle": true,
                  "horizontalAlignment": "Center"
                },
                {
                  "type": "TextBlock",
                  "text": "${completedCount} / ${totalCount}",
                  "size": "Large",
                  "weight": "Bolder",
                  "color": "Good",
                  "spacing": "None",
                  "horizontalAlignment": "Center"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "🔥 Streak",
                  "size": "Small",
                  "isSubtle": true,
                  "horizontalAlignment": "Center"
                },
                {
                  "type": "TextBlock",
                  "text": "${currentStreak} days",
                  "size": "Large",
                  "weight": "Bolder",
                  "color": "Warning",
                  "spacing": "None",
                  "horizontalAlignment": "Center"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "separator": true,
      "items": [
        {
          "type": "TextBlock",
          "text": "Next up",
          "size": "Small",
          "isSubtle": true,
          "horizontalAlignment": "Center"
        },
        {
          "type": "TextBlock",
          "text": "${nextHabitName}",
          "size": "Medium",
          "weight": "Bolder",
          "spacing": "None",
          "horizontalAlignment": "Center",
          "wrap": true
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Execute",
      "title": "✅ Complete Next",
      "verb": "complete-next",
      "style": "positive"
    },
    {
      "type": "Action.Execute",
      "title": "⏭️ Skip",
      "verb": "skip-next"
    },
    {
      "type": "Action.Execute",
      "title": "🏠 Open App",
      "verb": "open-app"
    }
  ]
}
