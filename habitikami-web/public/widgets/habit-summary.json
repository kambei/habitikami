{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "items": [
        {
          "type": "TextBlock",
          "text": "🏯 Habitikami",
          "size": "Medium",
          "weight": "Bolder",
          "color": "Accent"
        },
        {
          "type": "TextBlock",
          "text": "${date}",
          "size": "Small",
          "isSubtle": true,
          "spacing": "None"
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Completed",
                  "size": "Small",
                  "isSubtle": true
                },
                {
                  "type": "TextBlock",
                  "text": "${completedCount} / ${totalCount}",
                  "size": "ExtraLarge",
                  "weight": "Bolder",
                  "color": "Good",
                  "spacing": "None"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "🔥 Streak",
                  "size": "Small",
                  "isSubtle": true
                },
                {
                  "type": "TextBlock",
                  "text": "${currentStreak} days",
                  "size": "ExtraLarge",
                  "weight": "Bolder",
                  "color": "Warning",
                  "spacing": "None"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "Container",
      "spacing": "Medium",
      "items": [
        {
          "type": "TextBlock",
          "text": "Next up",
          "size": "Small",
          "isSubtle": true
        },
        {
          "type": "TextBlock",
          "text": "${nextHabitName}",
          "weight": "Bolder",
          "spacing": "None"
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Execute",
      "title": "Open Habitikami",
      "verb": "open-app"
    },
    {
      "type": "Action.Execute",
      "title": "✅ Complete Next",
      "verb": "complete-next"
    }
  ]
}
